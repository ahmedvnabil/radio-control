# ──────────── Core ────────────
AZURACAST_BASE_URL=https://radio.zad.tools
AZURACAST_API_KEY=
SECRET_KEY=change-me-in-prod
PORT=4180
DEBUG=false
DEFAULT_LANG=ar
QUEUE_BUILDER_INTERVAL=30

# ──────────── AI Assistant (OpenAI Chat) ────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ──────────── Local backend integrations ────────────
# Point these at services on your Proxmox/Coolify network. Each is optional.

# Guide app (the one in Proxmox-Server-Guide/scripts/server.py)
# Exposes /api/radio/* and /api/music-brand/*  → preferred entry point
GUIDE_BASE_URL=
GUIDE_TOKEN=

# VoiceBox Gateway (Arabic TTS) — fallback if GUIDE_BASE_URL doesn't proxy it
# ex: http://192.168.70.194:11000
VOICEBOX_BASE_URL=

# ACE-Step (text-to-music container) — for the inject endpoint
# ex: http://192.168.70.164:3001
ACE_STEP_BASE_URL=

# FreeLLM Gateway — OpenAI-compatible API for /generate-script
# ex: http://192.168.70.x:8080
FREELLM_BASE_URL=
FREELLM_API_KEY=

# ──────────── Telegram broadcasts to followers ────────────
# Leave the token empty to keep the whole feature dormant. Rules live in
# agents/broadcasts.yaml (editable). TZ controls when show_start rules fire.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # @your_channel  or  -1001234567890
TZ=Africa/Cairo           # show start times are matched against this timezone
